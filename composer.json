{
    "name": "mykolapodpriatov/drupal-d7-to-d11-migration-kit",
    "description": "Drop-in migration module for Drupal 7 to Drupal 11 with ready-made YAML configs and custom process plugins for common pain points.",
    "type": "drupal-module",
    "license": "MIT",
    "homepage": "https://github.com/mykolapodpriatov/drupal-d7-to-d11-migration-kit",
    "keywords": [
        "drupal",
        "drupal11",
        "drupal7",
        "migration",
        "migrate",
        "field_collection",
        "paragraphs"
    ],
    "require": {
        "php": ">=8.3",
        "drupal/core": "^11",
        "drupal/migrate_plus": "^6",
        "drupal/migrate_tools": "^6",
        "drupal/paragraphs": "^1.18",
        "drupal/redirect": "^1.10"
    },
    "suggest": {
        "drupal/media_migration": "Required when migrating D7 file-attached fields into D11 media entities."
    },
    "require-dev": {
        "drupal/core-dev": "^11",
        "phpstan/phpstan": "^1.11",
        "mglaman/phpstan-drupal": "^1.2",
        "squizlabs/php_codesniffer": "^3.10",
        "drupal/coder": "^8.3"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],
    "extra": {
        "installer-name": "d7_to_d11_migrations"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "drupal/core-composer-scaffold": true,
            "phpstan/extension-installer": true,
            "php-http/discovery": true,
            "tbachert/spi": true
        }
    }
}
