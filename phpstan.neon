parameters:
  level: 5
  paths:
    - src
    - tests
  excludePaths:
    - vendor
  treatPhpDocTypesAsCertain: false
  ignoreErrors:
    # lookupMediaUuidByPath() is a documented extension point: the default
    # implementation returns NULL, but subclasses may return a media UUID.
    -
      message: '#never returns string so it can be removed from the return type#'
      path: src/Plugin/migrate/process/RewriteMediaEmbeds.php
